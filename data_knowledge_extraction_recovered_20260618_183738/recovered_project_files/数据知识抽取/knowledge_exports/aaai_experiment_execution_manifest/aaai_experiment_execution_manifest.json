  "systematic_ablation_plan": [
    {
      "name": "Anchor only",
      "intervention": "remove all challengers and reliability correction"
    },
    {
      "name": "Unfiltered evidence",
      "intervention": "use all generated evidence without reliability admission"
    },
    {
      "name": "Expert only",
      "intervention": "keep expert mechanism evidence; remove LLM/statistical sources"
    },
    {
      "name": "LLM only",
      "intervention": "keep LLM-generated weak-class rules; remove expert/statistical sources"
    },
    {
      "name": "Lag/residual only",
      "intervention": "keep lag and residual triggers; remove expert/LLM graph evidence"
    },
    {
      "name": "Graph only",
      "intervention": "keep graph path evidence; remove residual and source reliability channels"
    },
    {
      "name": "No counterfactual guard",
      "intervention": "remove C_k perturbation-dependence admission"
    },
    {
      "name": "No tail safety",
      "intervention": "remove H_k low-tail harm control"
    },
    {
      "name": "No complexity penalty",
      "intervention": "remove B_k path/source burden"
    },
    {
      "name": "Full model",
